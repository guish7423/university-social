# ========================================
# 大学社交平台 — 环境变量配置
# ========================================

# --- 数据库 ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/university_social?sslmode=disable

# --- Redis ---
REDIS_ADDR=localhost:6379

# --- 服务 ---
SERVER_ADDR=:8081

# --- JWT ---
JWT_SECRET=change-me-to-a-random-string-in-production

# --- 微信小程序 ---
WECHAT_APP_ID=wx6b954270be06ae85
WECHAT_SECRET=your-wechat-secret

# --- 管理员（逗号分隔的用户ID） ---
ADMIN_USER_IDS=1

# --- MinIO（文件存储，可选） ---
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=university-social
